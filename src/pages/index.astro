---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Turnen in Hengelo | Sportvereniging H.G.V.';
const description = 'Van voorbereidend turnen (4+) tot jeugd en volwassenen. Ontdek wat er in Hengelo allemaal mogelijk is en welke sporten bij jou passen.';
const heroImage = '/images/hero.avif';
---

<BaseLayout title={title} description={description} heroImage={heroImage}>
  <!-- Hero Section -->
  <section id="hero" class="hero" aria-label="Hoofdsectie">
    <picture class="hero-background" aria-hidden="true">
      <source type="image/avif" srcset="/images/hero.avif" />
      <source type="image/webp" srcset="/images/hero.webp" />
      <img 
        src="/images/hero.webp" 
        alt="" 
        loading="eager" 
        fetchpriority="high"
        width="2002"
        height="3648"
        decoding="async"
        sizes="100vw"
        onload="this.classList.add('loaded'); this.closest('.hero')?.classList.add('image-loaded')"
      />
    </picture>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content container">
      <span class="hero-badge fade-in">H.G.V. Hengelo</span>
      <h1 class="hero-title fade-in">Turnen in <span class="text-primary-gradient">Hengelo</span></h1>
      <p class="hero-subtitle fade-in">Van voorbereidend turnen (4+) tot jeugd en volwassenen<br />met aandacht voor plezier, veiligheid en groei.</p>
      <nav class="hero-cta fade-in" aria-label="Call-to-action navigatie">
        <a href="#over" class="btn">Ontdek Turnen</a>
        <a href="#varianten" class="btn btn-secondary">Alle Sporten</a>
      </nav>
    </div>
    <a href="#over" class="hero-scroll-indicator" aria-label="Scroll naar beneden">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 5v14M12 19l-7-7M12 19l7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <!-- Introductie -->
  <section id="over" class="section">
    <div class="container">
      <div class="section-header" data-animate>
        <h2 class="text-center">Hengelo turnt</h2>
        <p class="section-intro text-center">Welkom bij Turnen Hengelo! Op deze pagina lees je alles over turnlessen en -activiteiten binnen onze vereniging. We leggen uit wat turnen inhoudt, welke varianten er zijn, en hoe jij kunt beginnen — op jouw eigen niveau.</p>
      </div>
    </div>
  </section>

  <!-- Over turnen -->
  <section class="section section-alt">
    <div class="container">
      <div class="content-with-image" data-animate>
        <div class="content-text">
          <span class="badge mb-sm">Methodiek</span>
          <h2>Wat houdt turnen in?</h2>
          <p>Turnen is méér dan trucjes uitvoeren. Je werkt aan techniek, lenigheid, kracht, balans, coördinatie en zelfvertrouwen. Onze trainingen zijn opgebouwd met aandacht voor veiligheid, ontwikkeling en plezier.</p>
          <p>Elke sporter traint op zijn of haar eigen niveau, binnen kleine groepen en onder begeleiding van gediplomeerde trainers.</p>
          <a href="#contact" class="btn btn-secondary mt-md">Kom een keertje kijken</a>
        </div>
        <div class="content-image-wrapper">
          <picture>
            <source type="image/avif" srcset="/images/Turnen1.avif" />
            <source type="image/webp" srcset="/images/Turnen1.webp" />
            <img 
              src="/images/Turnen1.webp" 
              alt="Turnen in actie" 
              loading="lazy" 
              width="800"
              height="600"
              decoding="async"
              class="rounded-lg shadow-2xl"
            />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- Voor wie is turnen? -->
  <section class="section">
    <div class="container">
      <h2 class="text-center mb-xl" data-animate>Voor wie is turnen?</h2>

      <div class="content-grid">
        <div class="feature-card card" data-animate data-delay="1">
          <div class="icon-circle bg-primary-soft">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Turnen voor iedereen</h3>
          <p class="text-muted">Turnen is geschikt voor alle leeftijden. Ook als je slechts één keer per week wilt trainen, kun je volledig meedoen binnen je eigen niveau.</p>
        </div>
        
        <div class="feature-card card" data-animate data-delay="2">
          <div class="icon-circle bg-primary-soft">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"/><path d="m12 8-4 4 4 4"/><path d="m16 12-4-4"/><path d="m16 12-4 4"/></svg>
          </div>
          <h3>Jongens en meisjes</h3>
          <p class="text-muted">In de lessen trainen jongens en meisjes samen. Samen trainen werkt motiverend en helpt bij het leren van nieuwe elementen op alle toestellen.</p>
        </div>
        
        <div class="feature-card card" data-animate data-delay="3">
          <div class="icon-circle bg-primary-soft">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22h14"/><path d="M5 2h14"/><path d="M17 22V2"/><path d="M7 22V2"/><path d="M17 11H7"/><path d="M17 5H7"/><path d="M17 17H7"/></svg>
          </div>
          <h3>Alle leeftijden</h3>
          <p class="text-muted">Van jonge beginners (4+) tot ervaren sporters: iedereen leert in zijn eigen tempo. Het niveauverschil binnen groepen zorgt juist voor een fijne dynamiek.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lesopbouw -->
  <section class="section section-alt">
    <div class="container">
      <div class="card p-xl border-primary" data-animate>
        <h2>Hoe ziet een turnles eruit?</h2>
        <p class="mb-lg">Onze turnlessen duren doorgaans langer dan een standaard gymles, zodat er ruimte is voor een volledige ervaring:</p>
        <div class="list-grid">
          <ul class="check-list">
            <li>Een actieve warming-up</li>
            <li>Specifieke techniektraining</li>
            <li>Leren van nieuwe elementen</li>
          </ul>
          <ul class="check-list">
            <li>Persoonlijke begeleiding</li>
            <li>Uitdaging op ieders niveau</li>
            <li>Samenwerken en groei</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Andere sporten & varianten -->
  <section id="varianten" class="section">
    <div class="container">
      <div class="section-header text-center" data-animate>
        <h2>Turnen is zoveel meer</h2>
        <p class="section-intro">Binnen Turnen Hengelo kun je verschillende disciplines ontdekken die aansluiten bij jouw interesses.</p>
      </div>
      
      <div class="card-grid">
        {[
          {
            id: 'rhonrad',
            title: 'Rhönradturnen',
            image: '/images/sports/rhonradturnen',
            desc: 'Turnen in een groot rad waarin je rollen, spiralen en sprongen leert uitvoeren.'
          },
          {
            id: 'groepsspringen',
            title: 'Groepsspringen',
            image: '/images/sports/groepsspringen',
            desc: 'Samen springen op vloer, mat en minitrampolines. Een dynamische teamsport.'
          },
          {
            id: 'trampoline',
            title: 'Trampolinespringen',
            image: '/images/sports/trampolinespringen',
            desc: 'Grote trampoline, series sprongen en creatieve bewegingen. Focus op balans.'
          },
          {
            id: 'airtrack',
            title: 'Airtrackspringen',
            image: '/images/sports/airtrackspringen',
            desc: 'Turnen op een lange, met lucht gevulde baan voor hogere en mooiere sprongen.'
          },
          {
            id: 'klimdoek',
            title: 'Klimdoekturnen',
            image: '/images/sports/Klimdoekturnen',
            desc: 'Acrobatics in lange, hangende doeken (Aerial silks). Kracht en elegantie.'
          },
          {
            id: 'acrogym',
            title: 'Acrogym',
            image: '/images/sports/acrogym',
            desc: 'Samenwerken in duo\'s of trio\'s met balanselementen en tilfiguren.'
          },
          {
            id: 'freerunning',
            title: 'Free-running',
            image: '/images/sports/freerunning',
            desc: 'De kunst om obstakels zo vloeiend en gecontroleerd mogelijk te nemen.'
          }
        ].map(sport => (
          <div class="card sport-card">
            <div class="sport-image">
              <picture>
                <source type="image/avif" srcset={`${sport.image}.avif`} />
                <source type="image/webp" srcset={`${sport.image}.webp`} />
                <img 
                  src={`${sport.image}.webp`} 
                  alt={sport.title} 
                  loading="lazy" 
                  width="500"
                  height="500"
                  decoding="async"
                />
              </picture>
            </div>
            <div class="card-content">
              <h3>{sport.title}</h3>
              <p class="text-muted">{sport.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kleding & veiligheid -->
  <section class="section section-alt">
    <div class="container">
      <div class="safety-box" data-animate>
        <div class="safety-icon">
          <svg width="40" height="40" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
        </div>
        <div>
          <h2>Kleding & veiligheid</h2>
          <div class="safety-grid">
            <div class="safety-item">
              <strong>Kleding</strong>
              <p>Strakke sportkleding zonder koorden of losse onderdelen.</p>
            </div>
            <div class="safety-item">
              <strong>Schoeisel</strong>
              <p>Vaak op blote voeten; bij trampoline sokken met grip.</p>
            </div>
            <div class="safety-item">
              <strong>Extra's</strong>
              <p>Haar vast, geen sieraden. Veiligheid staat voorop.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section">
    <div class="container">
      <div class="contact-card card" data-animate>
        <div class="contact-content">
          <h2>Klaar om te beginnen?</h2>
          <p class="mb-lg">Heb je vragen, wil je een keer meedoen of wil je meer weten over een van de sporten? We helpen je graag verder.</p>
          
          <div class="contact-links">
            <a href="tel:+31643118346" class="contact-link">
              <span class="icon-circle bg-primary-soft">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <div>
                <span class="label">Bel of WhatsApp</span>
                <span class="value">06-43118346</span>
              </div>
            </a>
            
            <a href="mailto:secretariaat@hgvhengelo.nl" class="contact-link">
              <span class="icon-circle bg-primary-soft">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-11 11M22 2l-7 20-4-9-9-4 20-7z"/></svg>
              </span>
              <div>
                <span class="label">E-mail ons</span>
                <span class="value">secretariaat@hgvhengelo.nl</span>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0f172a;
    color: var(--color-white);
    text-align: center;
    padding: var(--spacing-2xl) 0;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    opacity: 0.6;
    transition: scale 10s ease-out;
  }

  .hero.image-loaded .hero-background img {
    scale: 1.1;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.8));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 2rem;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  .hero-title {
    margin-bottom: 1.5rem;
  }

  .text-primary-gradient {
    background: linear-gradient(to right, var(--color-primary), #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 3rem;
    opacity: 0.9;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .hero-subtitle {
      font-size: 1.75rem;
    }
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .hero-cta {
      flex-direction: row;
    }
  }

  /* Hero scroll indicator */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: color var(--transition-base), border-color var(--transition-base), background-color var(--transition-base);
    text-decoration: none;
  }

  .hero-scroll-indicator:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.6);
    background-color: rgba(255, 255, 255, 0.1);
    text-decoration: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-scroll-indicator svg {
      animation: bounce 2s ease-in-out infinite;
    }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .hero-cta .btn-secondary {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(8px);
  }

  .hero-cta .btn-secondary:hover {
    background-color: var(--color-white);
    color: var(--color-primary);
    border-color: var(--color-white);
  }

  /* Section Styles */
  .section-header {
    max-width: 700px;
    margin: 0 auto var(--spacing-xl);
  }

  .section-intro {
    font-size: 1.25rem;
    color: var(--color-text-muted);
  }

  /* Content with Image */
  .content-with-image {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .content-with-image {
      grid-template-columns: 1fr 1fr;
    }
  }

  .content-image-wrapper img {
    width: 100%;
    height: auto;
    border-radius: 2rem;
  }

  /* Cards */
  .feature-card {
    text-align: center;
    padding: var(--spacing-xl) var(--spacing-lg);
    cursor: default;
  }

  /* Disable lift-hover for non-interactive feature cards */
  .feature-card:hover {
    transform: none;
    box-shadow: none;
    border-color: var(--color-border);
  }

  .icon-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    color: var(--color-primary);
  }

  .bg-primary-soft {
    background-color: var(--color-primary-soft);
  }

  /* Sport Cards */
  .sport-card {
    padding: 0;
    overflow: hidden;
  }

  .sport-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--color-bg-light);
  }

  .sport-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .sport-card:hover .sport-image img {
    transform: scale(1.1);
  }

  .card-content {
    padding: var(--spacing-md);
  }

  /* Lists */
  .list-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .list-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .check-list li::before {
    background-color: var(--color-primary);
    content: "✓" !important;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.75rem;
    font-weight: 900;
    transform: none !important;
  }

  /* Safety Box */
  .safety-box {
    background-color: var(--color-white);
    border-radius: 2rem;
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .safety-box {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .safety-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  /* Contact */
  .contact-card {
    background: linear-gradient(135deg, var(--color-text) 0%, #1e293b 100%);
    color: var(--color-white);
    padding: var(--spacing-xl);
    border: none;
  }

  .contact-card h2 {
    color: var(--color-white);
  }

  .contact-links {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .contact-links {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background-color: rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid transparent;
    transition: background-color var(--transition-base), border-color var(--transition-base);
    cursor: pointer;
  }

  .contact-link:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .contact-link .label {
    display: block;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
    margin-bottom: 0.25rem;
  }

  .contact-link .value {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  /* Utility */
  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-primary-soft);
    color: var(--color-primary);
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .text-center { text-align: center; }
  .rounded-lg { border-radius: 1rem; }
  .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); }
  .p-xl { padding: var(--spacing-xl); }
  .border-primary { border: 2px solid var(--color-primary-soft); }

  /* Fade-in delays */
  @media (prefers-reduced-motion: no-preference) {
    .fade-in:nth-child(1) { animation-delay: 0.1s; }
    .fade-in:nth-child(2) { animation-delay: 0.3s; }
    .fade-in:nth-child(3) { animation-delay: 0.5s; }
    .fade-in:nth-child(4) { animation-delay: 0.7s; }
  }
</style>

<script>
  // Scroll-reveal via IntersectionObserver
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));
</script>

