---
const currentYear = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container footer-grid">
    <div class="footer-brand">
      <h2 class="footer-logo">Turnen <span class="text-primary">Hengelo</span></h2>
      <p class="footer-desc">Sportvereniging H.G.V. Hengelo biedt een breed scala aan gymnastiek- en turnlessen voor alle leeftijden en niveaus.</p>
      <div class="social-links">
        <a href="#" aria-label="Facebook" class="social-link">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="social-link">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-links">
      <h3 class="footer-heading">Navigatie</h3>
      <ul>
        <li><a href="#hero">Home</a></li>
        <li><a href="#over">Over ons</a></li>
        <li><a href="#varianten">Sporten</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h3 class="footer-heading">Sporten</h3>
      <ul>
        <li><a href="#varianten">Rhönradturnen</a></li>
        <li><a href="#varianten">Groepsspringen</a></li>
        <li><a href="#varianten">Trampolinespringen</a></li>
        <li><a href="#varianten">Free-running</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h3 class="footer-heading">Contact</h3>
      <p>Sportvereniging H.G.V.</p>
      <p>Hengelo, Overijssel</p>
      <p><a href="mailto:secretariaat@hgvhengelo.nl">secretariaat@hgvhengelo.nl</a></p>
    </div>
  </div>
  
  <div class="footer-bottom container">
    <p>&copy; {currentYear} Turnen Hengelo. Alle rechten voorbehouden.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #0f172a;
    color: var(--color-white);
    padding: var(--spacing-2xl) 0 var(--spacing-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
    }
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    color: var(--color-white);
    letter-spacing: -0.02em;
  }

  .text-primary {
    color: var(--color-primary);
  }

  .footer-desc {
    font-size: 1rem;
    opacity: 0.7;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 320px;
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    color: var(--color-white);
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.75rem;
    padding-left: 0;
  }

  .footer-links li::before {
    display: none;
  }

  .footer-links a {
    color: var(--color-white);
    opacity: 0.7;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--color-primary);
    padding-left: 5px;
  }

  .footer-contact p {
    font-size: 1rem;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }

  .footer-contact a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    color: var(--color-white);
    transition: all var(--transition-base);
  }

  .social-link:hover {
    background-color: var(--color-primary);
    transform: translateY(-3px);
  }

  .footer-bottom {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-md);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.5;
  }
</style>

